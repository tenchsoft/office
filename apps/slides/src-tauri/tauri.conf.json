{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tench Slides",
  "version": "0.1.0",
  "identifier": "com.tench.slides",
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Tench Slides",
        "width": 1280,
        "height": 820,
        "minWidth": 1040,
        "minHeight": 700,
        "resizable": true,
        "decorations": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  },
  "build": {
    "frontendDist": "./frontend"
  }
}
